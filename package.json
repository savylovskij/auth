{
  "name": "auth",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  },
  "scripts": {
    "prepare": "husky",
    "backend:dev": "pnpm --filter backend start:dev",
    "backend:build": "pnpm --filter backend build",
    "backend:prod": "pnpm --filter backend start:prod",
    "frontend:dev": "pnpm --filter frontend start",
    "frontend:build": "pnpm --filter frontend build",
    "e2e": "pnpm --filter e2e test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "db:up": "docker compose --env-file apps/backend/.env up -d",
    "db:down": "docker compose --env-file apps/backend/.env down",
    "db:logs": "docker compose --env-file apps/backend/.env logs -f postgres",
    "migration:generate": "pnpm --filter backend migration:generate",
    "migration:run": "pnpm --filter backend migration:run",
    "migration:revert": "pnpm --filter backend migration:revert",
    "migration:run:prod": "pnpm --filter backend migration:run:prod",
    "migration:revert:prod": "pnpm --filter backend migration:revert:prod"
  }
}
